# Copy this file to .env and fill in your own keys. Never commit a real .env file.

# --- Required ------------------------------------------------------------------
ANTHROPIC_API_KEY=

# --- Audio transcription (Groq Whisper) -----------------------------------------
GROQ_API_KEY=

# --- Agent voice (optional) ------------------------------------------------------
ELEVENLABS_API_KEY=

# CORS: comma-separated list of origins allowed to call the API. Only needed
# if you serve the frontend from a different origin than the backend -- for
# normal local use (uvicorn serving everything from localhost:8000), leave empty.
ALLOWED_ORIGINS=

# Request body size limit in bytes -- 40MB by default, enough for a recording
# with several screenshots. Increase if your recordings are longer.
MAX_BODY_BYTES=41943040

# --- Execution agent (optional -- sensible defaults apply) ----------------------
# Ceiling on browser actions per run.
AGENT_MAX_STEPS=120
# If set, fixes the timeout in seconds instead of scaling it automatically
# with the size of the plan.
# AGENT_TIMEOUT_SEG=600
# Set to true to run the browser headless (no visible window).
AGENT_HEADLESS=false

# --- Secrets vault encryption (postprocessing/crypto.py) ------------------------
# If not set, a key is generated automatically at ~/.hearvision/enc.key
# Without this key (or if it cannot be generated), Phase B credentials are
# never stored -- they are not silently downgraded to plain text.
# HEARVISION_ENC_KEY=
